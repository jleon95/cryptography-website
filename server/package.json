{
  "name": "server",
  "version": "0.0.0",
  "private": true,
  "engines": {
    "node": ">=24.0.0"
  },
  "prisma": {
    "seed": "tsx src/prisma/seed.ts"
  },
  "scripts": {
    "build": "tsc --build",
    "clean": "tsc --build --clean",
    "dev": "nodemon --watch src/ --ext ts --exec tsx app.ts",
    "start": "node app",
    "db:init": "npx prisma migrate deploy --schema=./src/prisma/schema.prisma && npx prisma db seed",
    "test": "vitest"
  },
  "description": "server",
  "author": {
    "name": ""
  },
  "main": "app.js",
  "dependencies": {
    "@prisma/client": "^5.9.1",
    "arktype": "^2.2.1",
    "cors": "^2.8.5",
    "debug": "^2.2.0",
    "express": "^4.18.2",
    "node-schedule": "^2.1.1",
    "pino": "^8.18.0",
    "prisma": "^5.9.1"
  },
  "devDependencies": {
    "@types/debug": "0.0.30",
    "@types/express": "^4.17.21",
    "@types/express-serve-static-core": "^4.17.43",
    "@types/mime": "^1.3.5",
    "@types/node": "^20.19.43",
    "@types/serve-static": "^1.15.5",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "eslint": "^8.56.0",
    "nodemon": "^3.1.14",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "eslintConfig": {
    "parser": "@typescript-eslint/parser",
    "parserOptions": {
      "ecmaVersion": "latest",
      "sourceType": "module"
    },
    "plugins": [
      "@typescript-eslint"
    ]
  }
}
