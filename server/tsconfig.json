{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es6",
    "lib": ["es6"],
    "sourceMap": true,
    "strict": true,
    "skipLibCheck": true,
    "exactOptionalPropertyTypes": true
  },
  "include": [
    "app.ts",
    "logger.ts",
    "src/**/*.ts",
    "environment.d.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
