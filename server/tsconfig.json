{
  "compilerOptions": {
    "module": "ES2022",
    "target": "ES2024",
    "lib": ["ES2024"],
    "sourceMap": true,
    "strict": true,
    "skipLibCheck": true,
    "exactOptionalPropertyTypes": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noUncheckedIndexedAccess": true
  },
  "include": [
    "app.ts",
    "logger.ts",
    "src/**/*.ts",
    "environment.d.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
